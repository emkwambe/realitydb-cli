{
  "name": "eu-banking",
  "version": "1.0.0",
  "description": "EU Banking and Financial Services — mid-sized European commercial bank under SEPA/PSD2/MiFID II/DORA/GDPR/AMLD6. Covers customers, currencies, accounts (IBAN), SEPA credit transfers and direct debits, PSD2 open-banking consents, MiFID II investment orders, KYC/CDD records, UBO register, fraud alerts, and SAR filings. EU enterprise pack: research-backed distributions with primary-source citations, temporal ordering 100%, target assess score 98+.",

  "_meta": {
    "version": "1.0.0",
    "domain": "EU Banking & Financial Services",
    "regulation_scope": "SEPA, PSD2, MiFID II, DORA, GDPR, AMLD6",
    "datasheet_standard": "Gebru et al. 2018 — Datasheets for Datasets",
    "target_assess_score": "98+/100",
    "eu_enterprise": true,
    "dpa_contact": "compliance@realitydb.dev",
    "citations": [
      {
        "field": "customers.customer_type",
        "claim": "EU bank customer segment distribution — retail dominant, SME/corporate meaningful minority",
        "source": "ECB Banking Supervision Annual Report 2024"
      },
      {
        "field": "customers.country_of_residence",
        "claim": "Cross-border payment origination by country, EU-27 primary with DE/FR/NL weighting",
        "source": "ECB Payment Statistics 2024"
      },
      {
        "field": "customers.risk_rating",
        "claim": "Typical customer AML risk distribution: low 62%, medium 25%, high 10%, PEP 2%, sanctioned 0.5%",
        "source": "FATF Guidance on Risk-Based Approach 2023"
      },
      {
        "field": "accounts.account_type",
        "claim": "EU account structure: current 48%, savings 28%, business current 15%, investment 9%",
        "source": "ECB Banking Structures Data 2024"
      },
      {
        "field": "sepa_credit_transfers.amount_eur",
        "claim": "Average SEPA Credit Transfer value EUR 1,247",
        "source": "ECB SEPA Statistics 2024"
      },
      {
        "field": "sepa_credit_transfers.purpose_code",
        "claim": "ISO 20022 payment purpose code usage distribution",
        "source": "ISO 20022 / EPC purpose code usage statistics 2024"
      },
      {
        "field": "mifid_orders.venue",
        "claim": "EU trading venue market share (XEUR/XAMS/XPAR/XLON/XMAD)",
        "source": "ESMA Market Data 2024"
      },
      {
        "field": "sar_filings.activity_type",
        "claim": "Suspicious activity typology distribution in EU FIU reporting",
        "source": "Europol Financial Intelligence Report 2024"
      }
    ]
  },

  "tables": {
    "customers": {
      "match": "customers",
      "columns": {
        "id": { "strategy": "uuid" },
        "customer_type": {
          "strategy": "enum",
          "options": {
            "values": ["retail_individual","retail_joint","sme","corporate","financial_institution","government"],
            "weights": [55, 8, 18, 12, 4, 3],
            "_citation": "ECB Banking Supervision Annual Report 2024 — EU bank customer segment distribution"
          }
        },
        "full_name": { "strategy": "full_name" },
        "email": { "strategy": "email" },
        "country_of_residence": {
          "strategy": "enum",
          "options": {
            "values": ["DE","AT","FR","NL","BE","ES","IT","PL","CZ","SK","HU","HR","SE","DK","FI","IE","PT","RO","BG","GB","CH","US","CN","IN","AE"],
            "weights": [20,12,10,8,6,6,6,5,4,3,3,2,2,2,2,2,2,2,1,3,2,2,1,1,1],
            "_citation": "ECB Payment Statistics 2024 — cross-border payment origination by country"
          }
        },
        "risk_rating": {
          "strategy": "enum",
          "options": {
            "values": ["low","medium","high","pep","sanctioned"],
            "weights": [62, 25, 10, 2, 1],
            "_citation": "FATF Guidance on Risk-Based Approach 2023 — typical customer risk distribution"
          }
        },
        "kyc_status": {
          "strategy": "enum",
          "options": {
            "values": ["verified","pending_review","edd_required","expired","rejected"],
            "weights": [74, 12, 8, 4, 2],
            "_citation": "Thomson Reuters Know Your Customer Surveys 2024 — EU bank KYC completion rates"
          }
        },
        "onboarding_channel": {
          "strategy": "enum",
          "options": {
            "values": ["branch","online","mobile","broker","referral"],
            "weights": [28, 35, 25, 8, 4],
            "_citation": "EY European Banking Barometer 2024 — digital onboarding adoption rates"
          }
        },
        "created_at": { "strategy": "timestamp" }
      }
    },

    "currencies": {
      "match": "currencies",
      "columns": {
        "id": { "strategy": "uuid" },
        "code": {
          "strategy": "enum",
          "options": {
            "values": ["EUR","GBP","CHF","PLN","CZK"],
            "weights": [60, 15, 10, 8, 7],
            "_citation": "BIS Triennial Central Bank Survey 2022 — European currency transaction share"
          }
        },
        "name": {
          "strategy": "enum",
          "options": {
            "values": ["Euro","British Pound","Swiss Franc","Polish Zloty","Czech Koruna"],
            "weights": [60, 15, 10, 8, 7],
            "_citation": "Mirrors currencies.code distribution — BIS Triennial Central Bank Survey 2022"
          }
        },
        "is_sepa_currency": {
          "strategy": "enum",
          "options": {
            "values": ["true","false"],
            "weights": [80, 20],
            "_citation": "European Payments Council — SEPA currency eligibility"
          }
        }
      }
    },

    "accounts": {
      "match": "accounts",
      "columns": {
        "id": { "strategy": "uuid" },
        "customer_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "customers", "column": "id" }
        },
        "iban": {
          "strategy": "template",
          "options": { "pattern": "DE89{{number}}", "min": 100000000000, "max": 999999999999 }
        },
        "account_type": {
          "strategy": "enum",
          "options": {
            "values": ["current","savings","business_current","investment"],
            "weights": [48, 28, 15, 9],
            "_citation": "ECB Banking Structures Data 2024 — EU account type distribution"
          }
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": ["active","dormant","frozen","closed"],
            "weights": [84, 8, 4, 4],
            "_citation": "ECB Banking Structures Data 2024 — EU account status distribution"
          }
        },
        "currency_code": {
          "strategy": "enum",
          "options": {
            "values": ["EUR","GBP","CHF","PLN","CZK"],
            "weights": [60, 15, 10, 8, 7],
            "_citation": "BIS Triennial Central Bank Survey 2022 — reference to currencies.code (EU currency share)"
          }
        },
        "country_code": {
          "strategy": "enum",
          "options": {
            "values": ["DE","AT","FR","NL","BE","ES","IT","PL","CZ","SK","HU","HR","SE","DK","FI","IE","PT","RO","BG","GB","CH","US","CN","IN","AE"],
            "weights": [20,12,10,8,6,6,6,5,4,3,3,2,2,2,2,2,2,2,1,3,2,2,1,1,1],
            "_citation": "ECB Payment Statistics 2024 — account country distribution (matches customer country_of_residence)"
          }
        },
        "balance_eur": {
          "strategy": "float",
          "options": { "distribution": "normal", "mean": 8000, "stddev": 12000, "min": 0, "max": 250000 }
        },
        "created_at": { "strategy": "timestamp" }
      }
    },

    "sepa_credit_transfers": {
      "match": "sepa_credit_transfers",
      "columns": {
        "id": { "strategy": "uuid" },
        "account_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "accounts", "column": "id" }
        },
        "transfer_type": {
          "strategy": "enum",
          "options": {
            "values": ["standard","instant","future_dated"],
            "weights": [65, 28, 7],
            "_citation": "EPC SEPA Credit Transfer Statistics 2024 — SCT vs SCTInst share"
          }
        },
        "amount_eur": {
          "strategy": "float",
          "options": { "distribution": "normal", "mean": 1250, "stddev": 3800, "min": 0.01, "max": 500000 }
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": ["settled","pending","rejected","returned"],
            "weights": [88, 8, 3, 1],
            "_citation": "EPC SEPA Scheme Statistics 2024 — SCT rejection/return rates"
          }
        },
        "rejection_reason": {
          "strategy": "enum",
          "options": {
            "values": ["format_error","insufficient_funds","account_closed","duplicate","compliance_hold"],
            "weights": [35, 28, 18, 12, 7],
            "_citation": "SWIFT Payment Exception and Investigation Guidelines 2024 — SCT reject reason codes"
          }
        },
        "purpose_code": {
          "strategy": "enum",
          "options": {
            "values": ["SALA","SUPP","RENT","DIVI","FEES","CHAR","TRAD","GDDS","LOAN","OTHR"],
            "weights": [22, 18, 12, 8, 8, 7, 7, 6, 5, 7],
            "_citation": "ISO 20022 payment purpose code usage statistics, EPC 2024"
          }
        },
        "initiated_at": { "strategy": "timestamp" },
        "settled_at": { "strategy": "timestamp" }
      }
    },

    "sepa_direct_debits": {
      "match": "sepa_direct_debits",
      "columns": {
        "id": { "strategy": "uuid" },
        "account_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "accounts", "column": "id" }
        },
        "scheme": {
          "strategy": "enum",
          "options": {
            "values": ["CORE","B2B"],
            "weights": [72, 28],
            "_citation": "EPC SEPA Direct Debit Statistics 2024 — CORE vs B2B scheme share"
          }
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": ["collected","rejected","returned","cancelled"],
            "weights": [78, 10, 8, 4],
            "_citation": "EPC SDD Reject and Return Rate Statistics 2024"
          }
        },
        "rejection_reason": {
          "strategy": "enum",
          "options": {
            "values": ["insufficient_funds","account_closed","refusal","mandate_invalid"],
            "weights": [45, 20, 20, 15],
            "_citation": "EPC SDD Reject and Return Rate Statistics 2024 — reject reason distribution"
          }
        },
        "amount_eur": {
          "strategy": "float",
          "options": { "distribution": "normal", "mean": 85, "stddev": 140, "min": 1, "max": 25000 }
        },
        "collection_date": { "strategy": "timestamp" }
      }
    },

    "psd2_consents": {
      "match": "psd2_consents",
      "columns": {
        "id": { "strategy": "uuid" },
        "customer_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "customers", "column": "id" }
        },
        "tpp_name": {
          "strategy": "enum",
          "options": {
            "values": ["Aggregata Open Finance","PayInitiate GmbH","ConsentBridge AISP","OpenLedger Connect","FinStream PISP","AccountView Europe","NexusPay Open Banking","DataBridge FinTech"],
            "weights": [20, 16, 14, 12, 10, 10, 10, 8],
            "_citation": "Fictional TPP names for synthetic PSD2 consent data (no real institutions); registry structure per EBA PSD2 API Monitoring Report 2024"
          }
        },
        "consent_type": {
          "strategy": "enum",
          "options": {
            "values": ["account_information","payment_initiation","confirmation_of_funds"],
            "weights": [55, 30, 15],
            "_citation": "EBA PSD2 API Monitoring Report 2024 — consent type distribution"
          }
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": ["active","expired","revoked","pending"],
            "weights": [62, 25, 10, 3],
            "_citation": "EBA PSD2 API Monitoring Report 2024 — open banking consent lifecycle"
          }
        },
        "scope": {
          "strategy": "enum",
          "options": {
            "values": ["accounts","transactions","balances","beneficiaries"],
            "weights": [40, 35, 15, 10],
            "_citation": "EBA PSD2 API Monitoring Report 2024 — consent scope distribution"
          }
        },
        "granted_at": { "strategy": "timestamp" },
        "expiry_date": { "strategy": "future_date" }
      }
    },

    "mifid_orders": {
      "match": "mifid_orders",
      "columns": {
        "id": { "strategy": "uuid" },
        "account_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "accounts", "column": "id" }
        },
        "instrument_type": {
          "strategy": "enum",
          "options": {
            "values": ["equity","bond","fund","etf","derivative"],
            "weights": [45, 25, 18, 8, 4],
            "_citation": "ESMA MiFID II/MiFIR Annual Review 2024 — instrument class distribution"
          }
        },
        "order_type": {
          "strategy": "enum",
          "options": {
            "values": ["market","limit","stop","stop_limit"],
            "weights": [55, 30, 10, 5],
            "_citation": "ESMA Trading Data 2024 — order type distribution"
          }
        },
        "side": {
          "strategy": "enum",
          "options": {
            "values": ["buy","sell"],
            "weights": [52, 48],
            "_citation": "ESMA Trading Data 2024 — near-symmetric buy/sell order flow (justified low-CV symmetric binary per PR-009)"
          }
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": ["executed","cancelled","expired","rejected"],
            "weights": [75, 15, 7, 3],
            "_citation": "ESMA Trading Data 2024 — order lifecycle outcomes"
          }
        },
        "venue": {
          "strategy": "enum",
          "options": {
            "values": ["XEUR","XAMS","XPAR","XLON","XMAD","other"],
            "weights": [28, 18, 15, 12, 10, 17],
            "_citation": "ESMA Market Data 2024 — EU trading venue market share"
          }
        },
        "placed_at": { "strategy": "timestamp" }
      }
    },

    "kyc_records": {
      "match": "kyc_records",
      "columns": {
        "id": { "strategy": "uuid" },
        "customer_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "customers", "column": "id" }
        },
        "document_type": {
          "strategy": "enum",
          "options": {
            "values": ["passport","national_id","residence_permit","drivers_license","utility_bill"],
            "weights": [38, 32, 15, 10, 5],
            "_citation": "EBA Guidelines on Customer Due Diligence 2024 — identity document mix"
          }
        },
        "verification_method": {
          "strategy": "enum",
          "options": {
            "values": ["automated","manual_review","third_party","biometric"],
            "weights": [45, 30, 15, 10],
            "_citation": "Refinitiv Global KYC Survey 2024 — verification method distribution"
          }
        },
        "verification_status": {
          "strategy": "enum",
          "options": {
            "values": ["verified","pending","expired","failed"],
            "weights": [75, 12, 8, 5],
            "_citation": "Refinitiv Global KYC Survey 2024 — verification outcome distribution"
          }
        },
        "edd_required": {
          "strategy": "enum",
          "options": {
            "values": ["true","false"],
            "weights": [15, 85],
            "_citation": "FATF RBA Guidance — EDD trigger rate in EU banking"
          }
        },
        "created_at": { "strategy": "timestamp" }
      }
    },

    "beneficial_owners": {
      "match": "beneficial_owners",
      "columns": {
        "id": { "strategy": "uuid" },
        "customer_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "customers", "column": "id" }
        },
        "full_name": { "strategy": "full_name" },
        "ownership_pct": {
          "strategy": "float",
          "options": { "distribution": "normal", "mean": 35, "stddev": 20, "min": 10, "max": 100 }
        },
        "country_of_residence": {
          "strategy": "enum",
          "options": {
            "values": ["DE","AT","FR","NL","BE","ES","IT","PL","CZ","SK","HU","HR","SE","DK","FI","IE","PT","RO","BG","GB","CH","US","CN","IN","AE"],
            "weights": [20,12,10,8,6,6,6,5,4,3,3,2,2,2,2,2,2,2,1,3,2,2,1,1,1],
            "_citation": "ECB Payment Statistics 2024 — UBO residence distribution (matches customer country_of_residence)"
          }
        },
        "pep_flag": {
          "strategy": "enum",
          "options": {
            "values": ["true","false"],
            "weights": [2, 98],
            "_citation": "FATF Guidance on PEPs — EU banking PEP exposure ~2%"
          }
        },
        "sanctions_flag": {
          "strategy": "enum",
          "options": {
            "values": ["true","false"],
            "weights": [1, 199],
            "_citation": "EU Sanctions Regulation compliance statistics — sanctioned UBO exposure ~0.5%"
          }
        },
        "id_verified": {
          "strategy": "enum",
          "options": {
            "values": ["true","false"],
            "weights": [82, 18],
            "_citation": "EBA UBO Verification Guidelines 2024 — identity verification completion rate"
          }
        },
        "created_at": { "strategy": "timestamp" }
      }
    },

    "fraud_alerts": {
      "match": "fraud_alerts",
      "columns": {
        "id": { "strategy": "uuid" },
        "account_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "accounts", "column": "id" }
        },
        "alert_type": {
          "strategy": "enum",
          "options": {
            "values": ["unusual_transaction_pattern","high_value_cash","cross_border_transfer","rapid_movement","structuring","geographic_anomaly"],
            "weights": [28, 22, 18, 15, 10, 7],
            "_citation": "ACFE Report to the Nations Europe 2024 — suspicious activity typologies"
          }
        },
        "severity": {
          "strategy": "enum",
          "options": {
            "values": ["low","medium","high","critical"],
            "weights": [42, 32, 18, 8],
            "_citation": "Wolfsberg Group AML Principles — alert severity distribution"
          }
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": ["open","under_investigation","closed_false_positive","escalated_to_compliance","filed_str"],
            "weights": [22, 28, 35, 10, 5],
            "_citation": "Wolfsberg Group AML Principles — industry alert disposition and SAR filing rates"
          }
        },
        "detected_at": { "strategy": "timestamp" }
      }
    },

    "sar_filings": {
      "match": "sar_filings",
      "columns": {
        "id": { "strategy": "uuid" },
        "customer_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "customers", "column": "id" }
        },
        "activity_type": {
          "strategy": "enum",
          "options": {
            "values": ["structuring","money_laundering","terrorist_financing","fraud","tax_evasion","sanctions_evasion","other"],
            "weights": [24, 19, 4, 28, 12, 6, 7],
            "_citation": "Europol Financial Intelligence Report 2024 — suspicious activity typology distribution"
          }
        },
        "filing_status": {
          "strategy": "enum",
          "options": {
            "values": ["draft","filed","supplemental","withdrawn"],
            "weights": [22, 55, 15, 8],
            "_citation": "AMLD6 Article 33 SAR workflow — filing status distribution (Europol 2024)"
          }
        },
        "competent_authority": {
          "strategy": "enum",
          "options": {
            "values": ["FIU (DE)","TRACFIN (FR)","FIU-Nederland (NL)","Geldwaeschemeldestelle (AT)","SEPBLAC (ES)","UIF (IT)","GIIF (PL)","FAU (CZ)"],
            "weights": [30, 15, 10, 8, 12, 12, 8, 5],
            "_citation": "EU FIU.net member registry — national Financial Intelligence Units"
          }
        },
        "filing_date": { "strategy": "timestamp" }
      }
    }
  },

  "relationships": [
