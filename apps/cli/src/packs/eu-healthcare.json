          "options": {
            "values": ["DE","FR","IT","ES","PL","RO","NL","BE","PT","GR","other_EU","other"],
            "weights": [18, 12, 10, 9, 7, 6, 5, 4, 3, 3, 15, 8],
            "_citation": "Eurostat Healthcare Statistics 2024 — EU patient country-of-birth distribution"
          }
        },
        "age_bracket": {
          "strategy": "enum",
          "options": {
            "values": ["0-17","18-44","45-64","65-79","80+"],
            "weights": [12, 25, 32, 21, 10],
            "_citation": "Eurostat Population Statistics 2024 — EU age bracket distribution"
          }
