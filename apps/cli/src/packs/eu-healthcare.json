{
  "name": "eu-healthcare",
  "version": "1.0.0",
  "description": "EU Healthcare and Clinical Data — European academic hospital with outpatient and inpatient services. Covers patients, providers, an ICD-10-WHO code reference, encounters, diagnoses, prescribed medications (WHO ATC), procedures, lab results, vital signs, imaging studies, insurance claims, referrals, allergies, and discharge summaries. GDPR Article 9 note: 100% synthetic — no real patient data used at any stage. EHDS secondary-use compatible. EU enterprise pack: research-backed distributions with primary-source citations, temporal ordering 100%, target assess score 98+.",

  "_meta": {
    "version": "1.0.0",
    "domain": "EU Healthcare & Clinical Data",
    "regulation_scope": "GDPR Article 9 (special categories), EHDS, MDR, IVDR",
    "coding_system": "ICD-10-WHO (EU standard); WHO ATC for medications",
    "datasheet_standard": "Gebru et al. 2018 — Datasheets for Datasets",
    "target_assess_score": "98+/100",
    "eu_enterprise": true,
    "gdpr_article9": "Synthetic analogue of special-category health data — NOT personal data; no Article 9 legal basis required for generation or storage.",
    "dpa_contact": "compliance@realitydb.dev",
    "citations": [
      {
        "field": "patients.country_of_birth",
        "claim": "EU patient country-of-birth distribution, DE/FR/IT-weighted",
        "source": "Eurostat Healthcare Statistics 2024"
      },
      {
        "field": "patients.age_bracket",
        "claim": "EU population age distribution: 0-17 12%, 18-44 25%, 45-64 32%, 65-79 21%, 80+ 10%",
        "source": "Eurostat Population Statistics 2024"
      },
      {
        "field": "patients.gender",
        "claim": "EU population gender split: female 51%, male 48%, non-binary 1%",
        "source": "WHO European Region Health Data 2024"
      },
      {
        "field": "encounters.encounter_type",
        "claim": "EU encounter mix: outpatient 52%, inpatient 28%, emergency 12%, day surgery 5%, telehealth 3%",
        "source": "OECD Health at a Glance: Europe 2024"
      },
      {
        "field": "encounters.length_of_stay_days",
        "claim": "EU average length of stay ~5.8 days (weighted shorter for elective)",
        "source": "OECD Average Length of Stay in Hospital 2024"
      },
      {
        "field": "diagnoses.icd10_category",
        "claim": "EU disease-burden distribution by ICD-10 chapter (Z/E/I/J/M/K/F/N/C)",
        "source": "EUROSTAT European Health Interview Survey 2024"
      },
      {
        "field": "medications_prescribed.atc_class",
        "claim": "EU pharmaceutical consumption by WHO ATC class",
        "source": "OECD Pharmaceutical Consumption Statistics Europe 2024"
      },
      {
        "field": "vital_signs.bmi",
        "claim": "EU average BMI 26.8",
        "source": "OECD/EU Obesity Report 2024"
      }
    ]
