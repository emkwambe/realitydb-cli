        "account_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "accounts", "column": "id" }
        },
        "direction": {
          "strategy": "enum",
          "options": {
            "values": ["outbound","inbound"],
            "weights": [0.55, 0.45]
          }
        },
        "transfer_type": {
          "strategy": "enum",
          "options": {
            "values": ["domestic_fedwire","international_SWIFT","internal_book_transfer"],
            "weights": [0.52, 0.28, 0.20]
          }
        },
        "amount_usd": {
          "strategy": "float",
          "options": { "distribution": "normal", "mean": 45000, "stddev": 85000, "min": 1000, "max": 5000000 }
        },
        "beneficiary_bank_country": {
          "strategy": "enum",
          "options": {
