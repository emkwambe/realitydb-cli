          }
        },
        "sec_code": {
          "strategy": "enum",
          "options": {
            "values": ["PPD","CCD","WEB"],
            "weights": [0.72, 0.18, 0.10],
            "_citation": "Nacha ACH Operating Rules 2022"
          }
        },
        "employer_category": {
          "strategy": "enum",
          "options": {
            "values": ["healthcare","technology","retail","manufacturing","government","education","financial_services","construction","other"],
