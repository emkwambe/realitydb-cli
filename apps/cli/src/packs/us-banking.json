          }
        },
        "deposited_at": {
          "strategy": "past_date",
          "options": { "minYearsAgo": 0, "maxYearsAgo": 2 }
        }
      }
    },

    "statements": {
      "match": "statements",
      "columns": {
        "id": { "strategy": "uuid" },
        "account_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "accounts", "column": "id" }
        },
        "statement_period": {
          "strategy": "enum",
          "options": {
            "values": ["January","February","March","April","May","June","July","August","September","October","November","December"],
            "weights": [0.0833, 0.0833, 0.0833, 0.0833, 0.0833, 0.0833, 0.0833, 0.0833, 0.0833, 0.0833, 0.0833, 0.0837]
          }
        },
        "opening_balance_usd": {
          "strategy": "float",
          "options": { "distribution": "normal", "mean": 8200, "stddev": 12000, "min": 0, "max": 500000 }
        },
        "closing_balance_usd": {
          "strategy": "float",
          "options": { "distribution": "normal", "mean": 8450, "stddev": 12000, "min": 0, "max": 500000 }
        },
        "total_credits_usd": {
          "strategy": "float",
          "options": { "distribution": "normal", "mean": 4200, "stddev": 3500, "min": 0, "max": 200000 }
        },
