          "options": {
            "values": ["completed","pending","returned","cancelled","held_for_review"],
            "weights": [0.82, 0.08, 0.04, 0.03, 0.03]
          }
        },
        "initiated_at": {
          "strategy": "past_date",
          "options": { "minYearsAgo": 0, "maxYearsAgo": 3 }
        },
        "settled_at": {
          "strategy": "timestamp",
          "options": {
            "dependsOn": "initiated_at",
            "dependencyRule": "after",
            "offsetMin": 0,
            "offsetMax": 2
          }
        }
      }
    },

    "direct_deposits": {
      "match": "direct_deposits",
      "columns": {
        "id": { "strategy": "uuid" },
        "account_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "accounts", "column": "id" }
        },
        "deposit_type": {
          "strategy": "enum",
          "options": {
            "values": ["payroll","government_benefit","social_security","pension","tax_refund","other"],
            "weights": [0.58, 0.14, 0.12, 0.08, 0.05, 0.03],
