{
  "name": "us-healthcare",
  "version": "1.0.0",
  "description": "14-table US healthcare dataset covering patients, providers, encounters, diagnoses, medications, procedures, lab results, vital signs, imaging, insurance claims, referrals, allergies, and discharge summaries. HIPAA-safe synthetic data. ICD-10-CM coding. MS-DRG. CMS payer mix. CDC/NHANES/AHRQ HCUP distributions.",

  "_meta": {
    "version": "1.0.0",
    "domain": "US Healthcare / Hospital Operations",
    "regulation_scope": "HIPAA Privacy Rule, HIPAA Security Rule, 42 CFR Part 2 (behavioral health)",
    "coding_standards": "ICD-10-CM, MS-DRG, NDC, CPT",
    "hipaa_note": "Synthetic data only. Not derived from real patient records. No PHI. No Business Associate Agreement required. Safe for analytics development, dashboard prototyping, and SQL training.",
    "target_assess_score": "98+/100",
    "country_coverage": ["US"],
    "data_sources": [
      "CDC NHANES 2017-2020 (BMI, vitals)",
      "AHRQ HCUP NIS 2020 (LOS, DRG, encounter mix)",
      "CMS Medicare FFS 2022 (payer mix, claim status)",
      "ClinCalc DrugStats 2022 (medication volumes)",
      "CDC NCHS 2021 (age/gender/language distribution)"
    ],
    "dpa_contact": "compliance@realitydb.dev",
    "citations": [
      {
        "field": "patients.state_of_birth",
        "claim": "US patient state-of-birth distribution, proportional to Census state populations",
        "source": "CDC NCHS 2021"
      },
      {
        "field": "patients.age_bracket",
        "claim": "US population age distribution: 0-17 22%, 18-44 35%, 45-64 26%, 65-79 12%, 80+ 5%",
        "source": "CDC NCHS 2021"
      },
      {
        "field": "patients.gender",
        "claim": "US population gender split: female 50.8%, male 49.0%, non-binary 0.2%",
        "source": "US Census Bureau 2022"
      },
      {
        "field": "encounters.encounter_type",
        "claim": "US encounter mix: outpatient 62%, inpatient 18%, emergency 14%, day surgery 5%, telehealth 1%",
        "source": "AHRQ HCUP 2020"
      },
      {
        "field": "encounters.length_of_stay_days",
        "claim": "US average length of stay ~4.5 days",
        "source": "CDC NCHS 2021"
      },
      {
        "field": "diagnoses.icd10_category",
        "claim": "US disease-burden distribution by ICD-10-CM chapter",
        "source": "CMS Medicare FFS 2022"
      },
      {
        "field": "medications_prescribed.drug_class",
        "claim": "US pharmaceutical consumption by drug class",
        "source": "ClinCalc DrugStats 2022"
      },
      {
        "field": "vital_signs.bmi",
        "claim": "US adult average BMI 29.0",
        "source": "CDC NHANES 2017-2020"
      }
    ]
  },

