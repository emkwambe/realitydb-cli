{
  "name": "fintech",
  "version": "2.0.0",
  "description": "Retail banking and payments fraud detection dataset. Covers customers, accounts, merchants, transactions, fraud alerts, KYC records, payment methods, and notifications. v2.0: full PK/FK wiring, research-backed distributions (Federal Reserve Diary of Consumer Payment Choice 2024, Alloy State of Fraud 2024, MerchantSavvy card fraud statistics), cardinality declarations, target assess score >= 97.",
  "tables": {
    "customers": {
      "match": "customers",
      "columns": {
        "id": { "strategy": "uuid" },
        "full_name": { "strategy": "full_name" },
        "email": {
          "strategy": "dependent_email",
          "options": {
            "derivesFrom": "full_name",
            "domains": ["gmail.com", "yahoo.com", "hotmail.com", "proton.me", "outlook.com"]
          }
        },
        "phone": { "strategy": "phone" },
        "country": {
          "strategy": "enum",
          "options": {
            "values": ["US", "GB", "CA", "AU", "DE", "FR"],
            "weights": [60, 10, 10, 5, 8, 7]
          }
        },
        "city": {
          "strategy": "enum",
          "options": {
            "values": [
              "New York", "Houston", "Chicago", "Phoenix", "Los Angeles", "Dallas",
              "London", "Manchester", "Birmingham",
              "Toronto", "Vancouver", "Calgary",
              "Sydney", "Melbourne", "Brisbane",
              "Berlin", "Munich", "Hamburg", "Frankfurt",
              "Paris", "Lyon", "Marseille"
            ],
            "weights": [10, 6, 6, 4, 5, 4, 5, 2, 2, 5, 2, 2, 3, 2, 1, 3, 2, 2, 2, 3, 2, 1]
          }
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": ["active", "suspended", "closed"],
            "weights": [85, 10, 5]
          }
        },
        "kyc_verified": {
          "strategy": "enum",
          "options": {
            "values": ["verified", "pending", "failed"],
            "weights": [78, 15, 7]
          }
        },
        "customer_segment": {
          "strategy": "enum",
          "options": {
            "values": ["retail", "premium", "business"],
            "weights": [70, 20, 10]
          }
        },
        "created_at": { "strategy": "timestamp" }
      }
    },
    "merchants": {
      "match": "merchants",
      "columns": {
        "id": { "strategy": "uuid" },
        "name": {
          "strategy": "dependent_enum",
          "options": {
            "dependsOn": "category",
            "map": {
              "grocery":       ["Metro Mart", "FreshGrove", "Daily Basket", "Corner Pantry", "Urban Grocer"],
              "restaurant":    ["Spice Garden", "The Curry House", "Noodle Bar", "Sakura Sushi", "La Trattoria"],
              "travel":        ["SkyHigh Airlines", "Global Stays", "Budget Inn", "City Cab", "Wanderlust Tours"],
              "entertainment": ["CityPlex Cinema", "GameZone", "StreamFest", "LiveNation Tickets"],
              "healthcare":    ["MedPlus Pharmacy", "HealthFirst Clinic", "DentalCare Plus", "VisionPro Opticians"],
              "retail":        ["TechHub Electronics", "StyleZone Apparel", "HomeGoods Plus", "SportsPro"],
              "online":        ["NetPay", "SwiftTransfer", "CryptoEx", "PayLink"],
              "other":         ["Other Merchant"]
            }
          }
        },
        "category": {
          "strategy": "enum",
          "options": {
            "values": ["retail", "restaurant", "travel", "entertainment", "healthcare", "grocery", "online", "other"],
            "weights": [22, 18, 12, 10, 8, 15, 10, 5]
          }
        },
        "country": {
          "strategy": "enum",
          "options": {
            "values": ["US", "GB", "CA", "AU", "DE", "FR"],
            "weights": [60, 10, 10, 5, 8, 7]
          }
        },
        "city": {
          "strategy": "enum",
          "options": {
            "values": [
              "New York", "Houston", "Chicago", "Phoenix", "Los Angeles", "Dallas",
              "London", "Manchester", "Birmingham",
              "Toronto", "Vancouver", "Calgary",
              "Sydney", "Melbourne", "Brisbane",
              "Berlin", "Munich", "Hamburg", "Frankfurt",
              "Paris", "Lyon", "Marseille"
            ],
            "weights": [10, 6, 6, 4, 5, 4, 5, 2, 2, 5, 2, 2, 3, 2, 1, 3, 2, 2, 2, 3, 2, 1]
          }
        },
        "risk_level": {
          "strategy": "enum",
          "options": {
            "values": ["low", "medium", "high"],
            "weights": [70, 22, 8]
          }
        },
        "created_at": { "strategy": "timestamp" }
      }
    },
    "accounts": {
      "match": "accounts",
      "columns": {
        "id": { "strategy": "uuid" },
        "customer_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "customers", "column": "id" }
        },
        "account_type": {
          "strategy": "enum",
          "options": {
            "values": ["checking", "savings", "credit", "investment"],
            "weights": [55, 25, 15, 5]
          }
        },
        "balance_usd": {
          "strategy": "float",
          "options": {
            "distribution": "normal",
            "mean": 8000,
            "stddev": 12000,
            "min": 0,
            "max": 250000
          }
        },
        "currency": {
          "strategy": "enum",
          "options": {
            "values": ["USD", "GBP", "CAD", "AUD", "EUR"],
            "weights": [65, 12, 10, 5, 8]
          }
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": ["active", "dormant", "closed", "frozen"],
            "weights": [80, 8, 7, 5]
          }
        },
        "created_at": { "strategy": "timestamp" }
      }
    },
    "payment_methods": {
      "match": "payment_methods",
      "columns": {
        "id": { "strategy": "uuid" },
        "customer_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "customers", "column": "id" }
        },
        "method_type": {
          "strategy": "enum",
          "options": {
            "values": ["credit_card", "debit_card", "mobile_wallet", "bank_transfer", "cash"],
            "weights": [35, 30, 20, 11, 4]
          }
        },
        "is_default": {
          "strategy": "enum",
          "options": {
            "values": ["true", "false"],
            "weights": [30, 70]
          }
        },
        "created_at": { "strategy": "timestamp" }
      }
    },
    "transactions": {
      "match": "transactions",
      "columns": {
        "id": { "strategy": "uuid" },
        "account_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "accounts", "column": "id" }
        },
        "merchant_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "merchants", "column": "id" }
        },
        "amount_usd": {
          "strategy": "float",
          "options": {
            "distribution": "normal",
            "mean": 85,
            "stddev": 140,
            "min": 5.00,
            "max": 15000
          }
        },
        "transaction_type": {
          "strategy": "enum",
          "options": {
            "values": ["purchase", "withdrawal", "deposit", "transfer", "refund"],
            "weights": [55, 15, 12, 12, 6]
          }
        },
        "payment_channel": {
          "strategy": "enum",
          "options": {
            "values": ["mobile", "online", "pos", "atm", "branch"],
            "weights": [35, 28, 25, 8, 4]
          }
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": ["completed", "pending", "failed", "reversed"],
            "weights": [88, 6, 4, 2]
          }
        },
        "is_fraud": {
          "strategy": "enum",
          "options": {
            "values": ["true", "false"],
            "weights": [1, 99]
          }
        },
        "location_country": {
          "strategy": "enum",
          "options": {
            "values": ["US", "GB", "CA", "AU", "DE", "FR", "other"],
            "weights": [50, 10, 10, 5, 10, 5, 10]
          }
        },
        "created_at": { "strategy": "timestamp" }
      }
    },
    "fraud_alerts": {
      "match": "fraud_alerts",
      "columns": {
        "id": { "strategy": "uuid" },
        "transaction_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "transactions", "column": "id" }
        },
        "alert_type": {
          "strategy": "enum",
          "options": {
            "values": ["velocity_check", "geo_anomaly", "amount_spike", "pattern_match", "device_change"],
            "weights": [30, 20, 25, 15, 10]
          }
        },
        "severity": {
          "strategy": "enum",
          "options": {
            "values": ["low", "medium", "high", "critical"],
            "weights": [45, 30, 18, 7]
          }
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": ["open", "investigating", "resolved", "false_positive"],
            "weights": [20, 30, 35, 15]
          }
        },
        "risk_score": {
          "strategy": "float",
          "options": {
            "distribution": "normal",
            "mean": 42,
            "stddev": 28,
            "min": 0,
            "max": 100
          }
        },
        "created_at": { "strategy": "timestamp" }
      }
    },
    "kyc_records": {
      "match": "kyc_records",
      "columns": {
        "id": { "strategy": "uuid" },
        "customer_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "customers", "column": "id" }
        },
        "document_type": {
          "strategy": "enum",
          "options": {
            "values": ["passport", "drivers_license", "national_id", "utility_bill"],
            "weights": [35, 40, 15, 10]
          }
        },
        "verification_status": {
          "strategy": "enum",
          "options": {
            "values": ["approved", "rejected", "pending_review"],
            "weights": [75, 10, 15]
          }
        },
        "risk_rating": {
          "strategy": "enum",
          "options": {
            "values": ["low", "medium", "high"],
            "weights": [65, 25, 10]
          }
        },
        "created_at": { "strategy": "timestamp" }
      }
    },
    "notifications": {
      "match": "notifications",
      "columns": {
        "id": { "strategy": "uuid" },
        "customer_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "customers", "column": "id" }
        },
        "notification_type": {
          "strategy": "enum",
          "options": {
            "values": ["transaction_alert", "fraud_warning", "account_update", "promotional", "security"],
            "weights": [45, 20, 15, 12, 8]
          }
        },
        "channel": {
          "strategy": "enum",
          "options": {
            "values": ["push", "email", "sms"],
            "weights": [50, 30, 20]
          }
        },
        "status": {
          "strategy": "enum",
          "options": {
            "values": ["sent", "delivered", "read", "failed"],
            "weights": [20, 45, 30, 5]
          }
        },
        "created_at": { "strategy": "timestamp" }
      }
    },
    "audit_logs": {
      "match": "audit_logs",
      "columns": {
        "id": { "strategy": "uuid" },
        "customer_id": {
          "strategy": "uuid",
          "foreignKey": { "table": "customers", "column": "id" }
        },
        "action": {
          "strategy": "enum",
          "options": {
            "values": ["login", "logout", "password_change", "transfer_initiated", "settings_update", "card_blocked"],
            "weights": [35, 30, 8, 15, 8, 4]
          }
        },
        "ip_address": { "strategy": "ip_address" },
        "created_at": { "strategy": "timestamp" }
      }
    }
  },
  "relationships": [
    {
      "targetTable": "accounts",
      "sourceTable": "customers",
      "cardinality": { "strategy": "poisson", "mean": 1.8, "min": 1, "max": 5 }
    },
    {
      "targetTable": "payment_methods",
      "sourceTable": "customers",
      "cardinality": { "strategy": "poisson", "mean": 2.2, "min": 1, "max": 6 }
    },
    {
      "targetTable": "transactions",
      "sourceTable": "accounts",
      "cardinality": { "strategy": "poisson", "mean": 8.2, "min": 1, "max": 48 }
    },
    {
      "targetTable": "fraud_alerts",
      "sourceTable": "transactions",
      "cardinality": { "strategy": "poisson", "mean": 0.08, "min": 0, "max": 3 }
    },
    {
      "targetTable": "kyc_records",
      "sourceTable": "customers",
      "cardinality": { "strategy": "poisson", "mean": 1.3, "min": 1, "max": 4 }
    },
    {
      "targetTable": "notifications",
      "sourceTable": "customers",
      "cardinality": { "strategy": "poisson", "mean": 6.0, "min": 0, "max": 30 }
    },
    {
      "targetTable": "audit_logs",
      "sourceTable": "customers",
      "cardinality": { "strategy": "poisson", "mean": 15.0, "min": 2, "max": 60 }
    }
  ]
}
