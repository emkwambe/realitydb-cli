{
  "name": "@realitydb/cli",
  "version": "2.45.0",
  "description": "Developer Reality Platform - realistic database environments from your schema",
  "license": "BSL-1.1",
  "keywords": [
    "database",
    "seed",
    "testing",
    "synthetic-data",
    "developer-tools",
    "postgres",
    "fake-data",
    "test-data",
    "reality-engine",
    "schema",
    "realitydb"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emkwambe/realitydb-cli.git"
  },
  "author": "Eddy Mkwambe",
  "homepage": "https://github.com/emkwambe/realitydb-cli",
  "bugs": {
    "url": "https://github.com/emkwambe/realitydb-cli/issues"
  },
  "bin": {
    "realitydb": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "build:tsc": "tsc",
    "clean": "rm -rf dist *.tsbuildinfo",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run postbuild && node smoke-test.cjs && node dist/index.js --version",
    "postbuild": "node -e \"const fs=require('fs');const p='dist/packs';if(!fs.existsSync(p))fs.mkdirSync(p,{recursive:true});fs.readdirSync('src/packs').forEach(f=>fs.copyFileSync('src/packs/'+f,p+'/'+f))\"",
    "test": "node smoke-test.cjs"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/open": "^6.2.1",
    "@types/pg": "^8.11.0",
    "commander": "^14.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "open": "^10.1.0",
    "pg": "^8.20.0"
  }
}
