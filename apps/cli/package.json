{
  "name": "realitydb",
  "version": "1.6.1",
  "description": "Developer Reality Platform - realistic database environments from your schema",
  "license": "MIT",
  "keywords": [
    "database",
    "seed",
    "testing",
    "synthetic-data",
    "developer-tools",
    "postgres",
    "fake-data",
    "test-data",
    "reality-engine",
    "schema",
    "realitydb"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/emkwambe/databox.git"
  },
  "author": "Eddy Mkwambe",
