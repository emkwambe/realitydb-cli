    "@databox/schema": "workspace:^",
    "@databox/shared": "workspace:^",
    "@databox/templates": "workspace:^",
    "commander": "^14.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
