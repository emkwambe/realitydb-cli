  "bugs": {
    "url": "https://github.com/emkwambe/databox/issues"
  },
  "bin": {
    "realitydb": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "build:tsc": "tsc",
